# Growth Engine — example .env (copy this file to .env and fill in)

# Meta Marketing API — System User Token (Business Manager → System Users → Generate New Token)
# Scope: ads_read only
META_ACCESS_TOKEN=

# Meta Graph API version (pin to a specific version, never "latest")
META_API_VERSION=v23.0

# Ad-account ID (`act_<id>`) — find via: curl /me/adaccounts or in the Ads Manager URL
META_AD_ACCOUNT_ID=

# Shopify Custom App (Shopify Admin → Apps → Develop apps → Create custom app)
# Read-only scopes: read_orders, read_products
SHOPIFY_STORE_DOMAIN=
SHOPIFY_ACCESS_TOKEN=

# Anthropic API key (only for the demo server in webapp/, optional)
ANTHROPIC_API_KEY=
