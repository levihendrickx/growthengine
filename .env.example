# Growth Engine — voorbeeld .env (kopieer dit bestand naar .env en vul in)

# Meta Marketing API — System User Token (Business Manager → System Users → Generate New Token)
# Scope: alleen ads_read
META_ACCESS_TOKEN=

# Meta Graph API versie (zet vast op een specifieke versie, niet "latest")
META_API_VERSION=v23.0

# Ad-account ID (`act_<id>`) — vind via: curl /me/adaccounts of in Ads Manager URL
META_AD_ACCOUNT_ID=

# Shopify Custom App (Shopify Admin → Apps → Develop apps → Create custom app)
# Read-only scopes: read_orders, read_products
SHOPIFY_STORE_DOMAIN=
SHOPIFY_ACCESS_TOKEN=

# Anthropic API key (alleen voor de demo-server in webapp/, optioneel)
ANTHROPIC_API_KEY=
