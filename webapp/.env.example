# Kopieer dit bestand naar .env en vul je API keys in
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
PORT=8001

# Python executable with janus_swi installed (run setup.bat once to create .venv)
OMEGACLAW_PYTHON=D:\mubashir\growthengine\.venv\Scripts\python.exe

# Root of the PeTTa checkout (folder containing src\main.pl and python\petta.py)
PETTA_PATH=D:\mubashir\growthengine

# Set to 1 when perf atoms carry fabricated `actions[]` (sample_data/atoms/performance/*.json
# with "synthetic": true). Downstream code surfaces a banner so demo audiences know the
# conversion numbers were generated by scripts/synthesize_actions.py, not real Meta data.
OMEGACLAW_SYNTHETIC_CONVERSIONS=0
