# ── Anthropic ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase ───────────────────────────────────────────────────
# Find these in your Supabase project: Settings → API

# Project URL (public — safe to commit to .env.example)
SUPABASE_URL=https://your-project-ref.supabase.co

# Anon / public key  (public — used client-side and for JWT verification)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key  (SECRET — server-side only, NEVER in client code)
# Only needed if you perform admin operations (bulk inserts, bypassing RLS, etc.)
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Server ─────────────────────────────────────────────────────
PORT=3000
